<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Reservas - UPTC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <a href="/" class="btn btn-secondary mb-3">⬅ Volver al Menú</a>
        <h2 class="mb-4">Gestión de Reservas</h2>

        <div class="card mb-4">
            <div class="card-header bg-success text-white">Solicitar Nuevo Espacio</div>
            <div class="card-body">
                <form id="formReserva">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Auditorio a Reservar</label>
                            <select id="recurso" class="form-select" required>
                                <option value="">Cargando auditorios...</option>
                                </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Fecha</label>
                            <input type="date" id="fecha" class="form-control" required>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Nombre del Solicitante</label>
                            <input type="text" id="solicitante" class="form-control" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Hora de Inicio</label>
                            <input type="time" id="horaInicio" class="form-control" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Hora de Fin</label>
                            <input type="time" id="horaFin" class="form-control" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Verificar Disponibilidad y Reservar</button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-dark text-white">Reservas Confirmadas</div>
            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Auditorio</th>
                            <th>Fecha</th>
                            <th>Horario</th>
                            <th>Solicitante</th>
                        </tr>
                    </thead>
                    <tbody id="tablaReservas">
                        </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        const cargarSelectRecursos = async () => {
            try {
                const respuesta = await fetch('/recursos');
                const recursos = await respuesta.json();
                
                const select = document.getElementById('recurso');
                select.innerHTML = '<option value="">Seleccione un auditorio...</option>'; 
                
                recursos.forEach(recurso => {
                    select.innerHTML += `<option value="${recurso._id}">${recurso.nombre} (Capacidad: ${recurso.capacidad})</option>`;
                });
            } catch (error) {
                console.error('Error al cargar recursos:', error);
            }
        };

        const cargarReservas = async () => {
            try {
                const respuesta = await fetch('/reservas');
                const reservas = await respuesta.json();
                
                const tbody = document.getElementById('tablaReservas');
                tbody.innerHTML = ''; 
                
                reservas.forEach(reserva => {
                    const nombreAuditorio = reserva.recurso ? reserva.recurso.nombre : 'Auditorio eliminado';

                    tbody.innerHTML += `
                        <tr>
                            <td><strong>${nombreAuditorio}</strong></td>
                            <td>${reserva.fecha}</td>
                            <td>${reserva.horaInicio} - ${reserva.horaFin}</td>
                            <td>${reserva.solicitante}</td>
                        </tr>
                    `;
                });
            } catch (error) {
                console.error('Error al cargar reservas:', error);
            }
        };

        document.getElementById('formReserva').addEventListener('submit', async (e) => {
            e.preventDefault(); 
            
            const nuevaReserva = {
                recurso: document.getElementById('recurso').value,
                fecha: document.getElementById('fecha').value,
                horaInicio: document.getElementById('horaInicio').value,
                horaFin: document.getElementById('horaFin').value,
                solicitante: document.getElementById('solicitante').value
            };

            try {
                const respuesta = await fetch('/reservas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(nuevaReserva)
                });

                if (respuesta.ok) {
                    alert('¡Éxito! Reserva asignada correctamente.');
                    document.getElementById('formReserva').reset(); 
                    cargarReservas(); 
                } else {
                    const error = await respuesta.json();
                    alert('RECHAZADO: ' + error.mensaje);
                }
            } catch (error) {
                console.error('Error al guardar:', error);
            }
        });

        cargarSelectRecursos();
        cargarReservas();
    </script>
</body>
</html>